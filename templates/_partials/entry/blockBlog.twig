{% set builder = builder ?? false %}
{% extends builder ? '_partials/matrix.twig' : '_partials/cke.twig' %}
{% set classWrapper = builder ? 'blocks blocks--blog' : 'inlines inlines--blog' %}
{% set classContent = builder ? 'blocks__popout' : '' %}
{% import '_macros/datastar' as macros %}

{% block content %}
  {% set blockId      = entry.id %}
  {% set limit        = 6 %}
  {% set filter       = craft.app.request.getQueryParam('filter') ?? '' %}
  {% set categories   = craft.entries.section('categories').all() %}
  {% set fetchAction  = datastar.get('_datastar/blog.twig', { offset: 0, entryId: blockId }) %}
  {% set filterEntry  = filter ? craft.entries.section('categories').slug(filter).one() : null %}
  {% set baseQuery    = craft.entries.section('blog').eagerly().orderBy('date DESC') %}
  {% set query        = filterEntry ? baseQuery.relatedTo(filterEntry) : baseQuery %}
  {% set fetchedEntries = query.limit(limit + 1).all() %}
  {% set hasMore        = fetchedEntries|length > limit %}
  {% set entries        = hasMore ? fetchedEntries|slice(0, limit) : fetchedEntries %}

  {% if categories %}
    <div class="inline-flex items-center mb-8 space-x-4"
      data-signals="{{ {('app' ~ blockId): {filter: filter}} | json_encode }}">
      {{ macros.urlSync([
        {name: 'filter', signal: 'app' ~ blockId ~ '.filter', default: '', type: 'string'}
      ]) }}
      <select
        data-bind:app{{ blockId }}.filter
        data-on:change="{{ fetchAction }}"
        data-attr:disabled="$blog_fetching"
        data-indicator:blog_fetching
        name="filter"
        aria-label="Blog-Kategorie filtern"
        class="ui-select ui-bold"
      >
        <option value="">{{ 'Show all'|t }}</option>
        {% for item in categories %}
          <option value="{{ item.slug }}" data-selected="$app{{ blockId }}.filter == '{{ item.slug }}'">
            {{ item.title }}
          </option>
        {% endfor %}
      </select>
      {% include '_components/spinner.twig' with {
        indicator: 'blog_fetching',
        size: 'size-6',
        class: 'ml-2'
      } only %}
    </div>
  {% endif %}

  <div id="result-{{ blockId }}">
    {% for entry in entries %}
      {{ entry.render() }}
    {% endfor %}
  </div>

  <div id="loadmore-{{ blockId }}">
    {% if hasMore %}
      <div class="mt-12">
        <button
          data-on:click="{{ datastar.get('_datastar/blog.twig', { offset: limit, entryId: blockId }) }}"
          data-indicator:blog_fetching
          data-attr:disabled="$blog_fetching"
          class="ui-btn inline-flex items-center gap-2"
        >
          {% include '_components/spinner.twig' with {
            indicator: 'blog_fetching',
            size: 'size-4'
          } only %}
          {{ 'Load more'|t }}
        </button>
      </div>
    {% endif %}
  </div>
{% endblock %}
