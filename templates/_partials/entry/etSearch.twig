{% set type = type ?? 'page' %}
{% import '_macros/datastar' as macros %}
{% set fetchAction = datastar.get('_datastar/search.twig', { type: type }) %}

<div class="space-y-4" data-signals="{ui: {search: ''}}">
  {% if type == 'page' %}
    {{ macros.urlSync([{ name: 'q', signal: 'ui.search', default: '', type: 'string' }], fetchAction) }}
  {% endif %}
  <div class="relative">
    <input
      id="searchInput-{{ type }}"
      type="text"
      class="ui-input w-full"
      placeholder="Type to search..."
      aria-label="Search"
      data-bind:ui.search
      data-on:input__debounce.300ms="{{ fetchAction }}"
      data-indicator:fetching
    />
    {% include '_components/spinner.twig' with {
      size: 'size-5',
      class: 'absolute right-3 top-1/2 -translate-y-1/2'
    } only %}
  </div>
  <div id="searchresult-{{ type }}">
    <p>
      💡 Try entering a search term, e.g. "frontend"
    </p>
  </div>
</div>
