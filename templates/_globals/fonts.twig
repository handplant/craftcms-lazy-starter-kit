{% set fontRegular = craft.vite.asset('fonts/archivo-v25-latin-regular.woff2', true) %}
{% set fontBold = craft.vite.asset('fonts/archivo-v25-latin-900.woff2', true) %}

<link rel="preload" as="font" type="font/woff2" crossorigin="anonymous" href="{{ fontRegular }}" />
<link rel="preload" as="font" type="font/woff2" crossorigin="anonymous" href="{{ fontBold }}" />

<style>
  @font-face { font-display: swap; font-family: 'Archivo'; font-style: normal; font-weight: 400; src: url('{{
    fontRegular
  }}') format('woff2'); }

  @font-face { font-display: swap; font-family: 'Archivo'; font-style: normal; font-weight: 900; src: url('{{
    fontBold
  }}') format('woff2'); }
</style>
