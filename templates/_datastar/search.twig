{% set type = type ?? 'page' %}
{% set search = signals.ui.search ?? null %}
{% set q = craft.entries.section(['blog', 'pages']) %}
{% set entries = search ? q.search(search).orderBy('score desc, postDate desc').limit(100).all : [] %}

{% if entries %}
  {% patchelements %}
    <div id="searchresult-{{ type }}">
      <p class="mb-4 ui-bold">
        {{ entries|length }} results
      </p>
      <div class="divide-y-2 divide-ink">
        {% for entry in entries %}
          <a
            href="{{ entry.url }}"
            class="flex items-center justify-between gap-4 py-3 font-bold hover:bg-pop-dim px-2 -mx-2 transition-colors duration-100"
          >
            <span>{{ entry.title }}</span>
            <span class="text-sm font-normal text-ink-dim shrink-0">{{ entry.section.handle }}</span>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endpatchelements %}
{% else %}
  {% patchelements %}
    <div id="searchresult-{{ type }}">
      {% if not search %}
        <p>
          💡 Try entering a search term, e.g. "frontend"
        </p>
      {% else %}
        <p class="ui-notice">
          🫣 No results for "{{ search }}" — try a different keyword.
        </p>
      {% endif %}
    </div>
  {% endpatchelements %}
{% endif %}
