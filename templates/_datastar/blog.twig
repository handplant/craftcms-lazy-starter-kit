{% set offset = offset ?? 0 %}
{% set limit = limit ?? 6 %}
{% set entryId = entryId ?? null %}
{% set filter = entryId ? (signals['app' ~ entryId].filter ?? '') : '' %}

{% set entryQuery = craft.entries.section('blog').eagerly().limit(limit + 1).offset(offset).orderBy('date DESC') %}

{% if filter %}
  {% set filterEntry = craft.entries.section('categories').slug(filter).one() %}
  {% do entryQuery.andRelatedTo(filterEntry) %}
{% endif %}

{% set fetchedEntries = entryQuery.all() %}
{% set hasMore = fetchedEntries|length > limit %}
{% set entries = hasMore ? fetchedEntries|slice(0, limit) : fetchedEntries %}

{% if not entries %}
  {% patchelements %}
    <div id="result-{{ entryId }}">
      <p class="ui-notice">
        🫣 No results{% if filter %}
          for "{{ filter }}"
        {% endif %}— try a different filter.
      </p>
    </div>
  {% endpatchelements %}
  {% patchelements %}
    <div id="loadmore-{{ entryId }}"></div>
  {% endpatchelements %}
{% else %}
  {% patchelements with { selector: '#result-' ~ entryId, mode: offset == 0 ? 'inner' : 'append' } %}
    {% for entry in entries %}
      {{ entry.render() }}
    {% endfor %}
  {% endpatchelements %}

  {% if hasMore %}
    {% patchelements %}
      <div id="loadmore-{{ entryId }}" class="mt-12">
        <button
          data-on:click="{{ datastar.get('_datastar/blog.twig', { offset: offset + limit, entryId: entryId }) }}"
          data-indicator:blog_fetching
          data-attr:disabled="$blog_fetching"
          class="ui-btn inline-flex items-center gap-2"
        >
          {% include '_components/spinner.twig' with {
            indicator: 'blog_fetching',
            size: 'size-4'
          } only %}
          {{ 'Load more'|t }}
        </button>
      </div>
    {% endpatchelements %}
  {% else %}
    {% patchelements %}
      <div id="loadmore-{{ entryId }}"></div>
    {% endpatchelements %}
  {% endif %}
{% endif %}
