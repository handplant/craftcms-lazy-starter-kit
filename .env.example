
# =========================================================
# 🌍 Environment Configuration
# =========================================================

# Craft environment: dev, staging, or production
CRAFT_ENVIRONMENT=dev

# System and caching options
IS_SYSTEM_LIVE=1
DEV_MODE=1
ALLOW_ADMIN_CHANGES=1
ALLOW_UPDATES=1
DISALLOW_ROBOTS=1
TEMPLATE_CACHE=0

# Content Signals (https://contentsignals.org)
CONTENT_SIGNAL_AI_TRAIN=no
CONTENT_SIGNAL_SEARCH=yes
CONTENT_SIGNAL_AI_INPUT=no


# =========================================================
# 🏠 Site Settings
# =========================================================

SITE_NAME="CraftCMS Lazy"
SEO_NAME="CraftCMS Lazy — A simple Craft CMS Starter Kit"

# The base URL of your Craft site
SITE_URL=https://craftcms-lazy.ddev.site


# =========================================================
# 🖼️ Asset Paths
# =========================================================

# File uploads
SITE_FILES_URL="@web/uploads/files"
SITE_FILES_PATH="@webroot/uploads/files"

# Image transforms
SITE_TRANSFORMS_URL="@web/uploads/transforms"
SITE_TRANSFORMS_PATH="@webroot/uploads/transforms"


# =========================================================
# 📧 Mail Settings
# =========================================================

# Default email addresses for system messages
EMAIL_SYSTEM_EMAIL_ADDRESS=you@example.com
EMAIL_REPLY_TO_ADDRESS=you@example.com
EMAIL_SENDER_NAME="CraftCMS Lazy"


# =========================================================
# 💾 Database Configuration
# =========================================================

CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=db
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=db
CRAFT_DB_USER=db
CRAFT_DB_PASSWORD=db
CRAFT_DB_SCHEMA=
CRAFT_DB_TABLE_PREFIX=


# =========================================================
# 🔐 Security
# =========================================================

# Unique application key (set this manually!)
CRAFT_SECURITY_KEY=changeMeToASecureRandomKey
